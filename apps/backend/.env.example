# Server configuration
SERVER_PORT=5001
NODE_ENV=development
# NODE_ENV=production

# Frontend URLs
FRONTEND_LOCAL_URL=http://localhost:3000
FRONTEND_SERVER_URL=https://your-frontend-domain.com

# Backend URLs
BACKEND_LOCAL_URL=http://localhost:5001
BACKEND_SERVER_URL=https://your-backend-domain.com

# Database configuration
# Example:
# postgres://USER:PASSWORD@HOST:PORT/DATABASE
# prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY
DATABASE_URL=YOUR_DATABASE_URL_HERE

# JWT authentication
JWT_ACCESS_SECRET=YOUR_ACCESS_TOKEN_SECRET
JWT_REFRESH_SECRET=YOUR_REFRESH_TOKEN_SECRET

# Token expiry (examples: 15m, 1h, 7d)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Local callback
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# Production callback (uncomment for prod)
# GOOGLE_CALLBACK_URL=https://your-backend-domain.com/api/auth/google/callback

# SMTP email (required for verification/reset email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=Consistify <no-reply@your-domain.com>
