# Frontend environment variables
# Used in: src/utils/api.ts, src/app/login/page.tsx, src/app/register/page.tsx,
# src/components/analytics/GoogleAnalytics.tsx

NODE_ENV=development
# NODE_ENV=production

# Local backend base URL (used in development)
NEXT_PUBLIC_BACKEND_LOCAL_URL=http://localhost:5001

# Production backend base URL (used when NODE_ENV=production)
NEXT_PUBLIC_BACKEND_SERVER_URL=https://your-backend-domain.com

# Google Analytics measurement ID (optional but recommended)
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
